# .env.example
# Copy this to .env and fill in your values.
# Never commit .env to version control.
#
# Load in your shell:  export $(cat .env | xargs)
# Or use python-dotenv in settings.py if you prefer.

# ── REQUIRED IN PRODUCTION ──────────────────────────────────────────────────

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-this-with-a-real-random-secret-key

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of your domain(s)
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (fine for small deployments)
# PostgreSQL: postgres://user:password@localhost:5432/timesdojo
DATABASE_URL=

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
PORT=8000
